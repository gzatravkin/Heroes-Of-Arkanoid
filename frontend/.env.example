# Firebase — create a project at console.firebase.google.com (Spark plan, no credit card)
# Copy this file to .env and fill in your project values.
# .env is gitignored; these keys are public (Firestore rules are the real access control).
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Play Games Services (optional — create leaderboards/achievements in Play Console)
# Only needed if you want GPGS leaderboards/achievements to appear in the Play Games app.
VITE_GPGS_LB_SOULS_WEEKLY=CgkI...
VITE_GPGS_LB_PROGRESSION=CgkI...
VITE_GPGS_ACH_FIRST_WIN=CgkI...
VITE_GPGS_ACH_CAMPAIGN_COMPLETE=CgkI...
VITE_GPGS_ACH_BEAT_BOSS=CgkI...
VITE_GPGS_ACH_PERFECT_RUN=CgkI...
VITE_GPGS_ACH_DIAMOND_LEAGUE=CgkI...
