rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles and nicknames — owner-write, public-read
    match /users/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Leaderboard scores — owner-write, public-read
    // Validation: souls must be a positive integer; no client can inflate another's score
    match /lb/{board}/scores/{uid} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.nickname is string
                   && request.resource.data.nickname.size() <= 32;
    }

    // Events — admin-write only (via Firebase Console or server SDK); public-read
    match /events/{eventId} {
      allow read:  if true;
      allow write: if false;
    }

    // Event participation — owner-write (claim own reward), owner-read
    match /events/{eventId}/participants/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Season results — Cloud Function writes (admin SDK); owner-read
    match /lb/seasons/{week}/scores/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
